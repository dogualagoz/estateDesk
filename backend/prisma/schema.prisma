generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
}

enum PropertyType {
  APARTMENT
  VILLA
  LAND
  HOTEL
  SHOP
  OFFICE
}

enum ListingType {
  SALE
  RENT
}

enum PortfolioVisibility {
  PUBLIC
  HIDDEN
}

enum DemandStatus {
  ACTIVE
  CLOSED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Office {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   @unique
  owner     User     @relation("OfficeOwner", fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    User[]      @relation("OfficeMembers")
  portfolios    Portfolio[]
  demands       Demand[]
  invites       Invite[]
  demandMatches DemandMatch[]
}

model Invite {
  id          String       @id @default(cuid())
  email       String
  token       String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  officeId    String
  office      Office       @relation(fields: [officeId], references: [id])
  invitedById String
  invitedBy   User         @relation("InviteCreatedBy", fields: [invitedById], references: [id])
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@index([officeId, status])
  @@index([token])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(AGENT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  officeId    String?
  office      Office?  @relation("OfficeMembers", fields: [officeId], references: [id])
  ownedOffice Office?  @relation("OfficeOwner")
  sentInvites Invite[] @relation("InviteCreatedBy")

  portfolios    Portfolio[]
  demands       Demand[]
  demandMatches DemandMatch[]
}

model Portfolio {
  id           String              @id @default(cuid())
  type         PropertyType
  listingType  ListingType         @default(SALE)
  title        String?
  city         String
  district     String
  neighborhood String?
  areaSqm      Int
  roomCount    String
  price        Decimal             @db.Decimal(14, 2)
  features     String[]            @default([])
  images       String[]            @default([])
  visibility   PortfolioVisibility @default(PUBLIC)
  note         String?
  ownerName    String
  ownerPhone   String

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  officeId String
  office   Office @relation(fields: [officeId], references: [id])

  demandMatches DemandMatch[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([officeId, type, city, district, visibility])
  @@index([officeId, deletedAt])
  @@index([deletedAt])
}

model Demand {
  id              String         @id @default(cuid())
  types           PropertyType[] @default([])
  listingType     ListingType    @default(SALE)
  regions         String[]       @default([])
  city            String?
  district        String?
  neighborhood    String?
  districts       String[]       @default([])
  neighborhoods   String[]       @default([])
  minBudget       Decimal?       @db.Decimal(14, 2)
  maxBudget       Decimal?       @db.Decimal(14, 2)
  roomPreferences String[]       @default([])
  minArea         Int?
  maxArea         Int?
  featurePrefs    String[]       @default([])
  mustHaveFeatures String[]      @default([])
  bonusFeatures   String[]       @default([])
  note            String?
  customerName    String
  customerPhone   String
  status          DemandStatus   @default(ACTIVE)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  officeId String
  office   Office @relation(fields: [officeId], references: [id])

  demandMatches DemandMatch[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([deletedAt])
  @@index([officeId, status])
  @@index([officeId, deletedAt])
  @@index([listingType, city, status])
}

model DemandMatch {
  id          String    @id @default(cuid())
  demandId    String
  demand      Demand    @relation(fields: [demandId], references: [id])
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
  officeId    String
  office      Office    @relation(fields: [officeId], references: [id])
  pinnedById  String
  pinnedBy    User      @relation(fields: [pinnedById], references: [id])
  pinnedAt    DateTime  @default(now())

  @@unique([demandId, portfolioId])
  @@index([demandId])
  @@index([portfolioId])
  @@index([officeId])
}
